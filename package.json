{
  "name": "visionary-guitar",
  "version": "1.0.0",
  "description": "Guitar scale visualization using real-time computer vision",
  "scripts": {
    "dev": "concurrently \"tsx watch --tsconfig tsconfig.node.json server.ts\" \"vite\"",
    "build": "vite build",
    "start": "NODE_ENV=production tsx --tsconfig tsconfig.node.json server.ts",
    "server": "tsx watch --tsconfig tsconfig.node.json server.ts"
  },
  "keywords": [
    "guitar",
    "scales",
    "computer-vision",
    "webrtc"
  ],
  "author": "Felipe Tomino",
  "repository": {
    "type": "git",
    "url": "https://github.com/felipe-tomino/visionary-guitar.git"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@roboflow/inference-sdk": "0.3.0",
    "dotenv": "17.3.1",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/vite": "4.2.1",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "autoprefixer": "10.4.27",
    "concurrently": "9.2.1",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "8.0.0"
  }
}